# Database
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/spaces_db?schema=public"

# Redis (spaces-own instance, separate from Core)
REDIS_URL="redis://:redis123@localhost:6380"

# Server
PORT=3005

# Auth
SPACES_SECRET_KEY="sk_spaces_dev_secret_change_in_prod"
SPACES_PUBLIC_KEY="pk_spaces_dev_public_change_in_prod"
JWT_SECRET="dev-jwt-secret-change-in-prod"

# Email (Resend)
RESEND_API_KEY="your-resend-api-key"
FROM_EMAIL="noreply@hsafa.com"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3005/api/auth/google/callback"

# Frontend URL (for OAuth redirects)
FRONTEND_URL="http://localhost:5180"

# Core connection (per-resource API keys)
HSAFA_GATEWAY_URL="https://core.hsafa.com"
CORE_SERVICE_KEY="hsk_service_..." # Generate via POST /api/keys { type: "service" } on Core

# ElevenLabs (TTS + STT)
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
