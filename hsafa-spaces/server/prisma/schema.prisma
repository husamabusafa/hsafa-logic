generator client {
  provider      = "prisma-client-js"
  output        = "./generated/client"
  engineType    = "library"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum EntityType {
  human
  agent
}

// =============================================================================
// USER — App-level auth (email/password)
// =============================================================================

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String?  @map("password_hash")
  hsafaEntityId  String?  @map("hsafa_entity_id")
  hsafaSpaceId   String?  @map("hsafa_space_id")
  agentEntityId  String?  @map("agent_entity_id")

  // Email verification
  emailVerified          Boolean   @default(false) @map("email_verified")
  verificationCode       String?   @map("verification_code")
  verificationCodeExpiry DateTime? @map("verification_code_expiry")

  // Google OAuth
  googleId       String?  @unique @map("google_id")
  avatarUrl      String?  @map("avatar_url")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  defaultBaseId    String?  @map("default_base_id") @db.Uuid

  haseefOwnerships HaseefOwnership[]
  apiKeys          ApiKey[]
  defaultBase      Base?    @relation("userDefaultBase", fields: [defaultBaseId], references: [id])

  @@map("users")
}

// =============================================================================
// ENTITY — Unified identity (Human or Agent)
// =============================================================================

model Entity {
  id          String     @id @db.Uuid
  type        EntityType
  externalId  String?    @unique @map("external_id")
  displayName String?    @map("display_name")
  metadata    Json?      @db.JsonB
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  smartSpaceMemberships SmartSpaceMembership[]
  messages              SmartSpaceMessage[]
  clients               Client[]
  sentInvitations       Invitation[]        @relation("inviter")
  receivedInvitations   Invitation[]        @relation("invitee")
  messageResponses      MessageResponse[]
  mediaAssets           MediaAsset[]
  haseefOwnerships      HaseefOwnership[]
  baseMemberships       BaseMember[]

  @@index([type])
  @@index([externalId])
  @@map("entities")
}

// =============================================================================
// SMART SPACE — Shared context space (timeline of events/messages)
// =============================================================================

model SmartSpace {
  id               String   @id @default(uuid()) @db.Uuid
  name             String?
  description      String?
  metadata         Json?    @db.JsonB
  inviteCode       String?  @unique @map("invite_code")
  inviteLinkActive Boolean  @default(true) @map("invite_link_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships      SmartSpaceMembership[]
  messages         SmartSpaceMessage[]
  invitations      Invitation[]
  messageResponses MessageResponse[]

  @@index([createdAt])
  @@map("smart_spaces")
}

// =============================================================================
// SMART SPACE MEMBERSHIP
// =============================================================================

model SmartSpaceMembership {
  id           String   @id @default(uuid()) @db.Uuid
  smartSpaceId String   @map("smart_space_id") @db.Uuid
  entityId     String   @map("entity_id") @db.Uuid
  role         String   @default("member") // "owner" | "admin" | "member"
  joinedAt     DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)

  lastSeenMessageId String? @map("last_seen_message_id") @db.Uuid

  smartSpace SmartSpace @relation(fields: [smartSpaceId], references: [id], onDelete: Cascade)
  entity     Entity     @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([smartSpaceId, entityId])
  @@index([entityId])
  @@map("smart_space_memberships")
}

// =============================================================================
// SMART SPACE MESSAGE — Messages/events in a SmartSpace
// =============================================================================

model SmartSpaceMessage {
  id           String   @id @default(uuid()) @db.Uuid
  smartSpaceId String   @map("smart_space_id") @db.Uuid
  entityId     String   @map("entity_id") @db.Uuid
  role         String
  content      String?  @db.Text
  metadata     Json?    @db.JsonB
  seq          BigInt
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  editedAt     DateTime? @map("edited_at") @db.Timestamptz(6)
  editHistory  Json?     @map("edit_history") @db.JsonB
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  smartSpace SmartSpace        @relation(fields: [smartSpaceId], references: [id], onDelete: Cascade)
  entity     Entity            @relation(fields: [entityId], references: [id])
  responses  MessageResponse[]

  @@unique([smartSpaceId, seq])
  @@index([smartSpaceId, createdAt])
  @@index([entityId])
  @@map("smart_space_messages")
}

// =============================================================================
// CLIENT — Connection points (web, mobile, node backend, etc.)
// =============================================================================

model Client {
  id           String    @id @default(uuid()) @db.Uuid
  entityId     String    @map("entity_id") @db.Uuid
  clientKey    String    @unique @map("client_key")
  clientType   String?   @map("client_type")
  displayName  String?   @map("display_name")
  capabilities Json      @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeenAt   DateTime? @map("last_seen_at") @db.Timestamptz(6)

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([clientType])
  @@map("clients")
}

// =============================================================================
// INVITATION — Space invitation system
// =============================================================================

model Invitation {
  id           String    @id @default(uuid()) @db.Uuid
  smartSpaceId String    @map("smart_space_id") @db.Uuid
  inviterId    String    @map("inviter_id") @db.Uuid
  inviteeEmail String    @map("invitee_email")
  inviteeId    String?   @map("invitee_id") @db.Uuid
  role         String    @default("member") // "member" | "admin"
  status       String    @default("pending") // "pending" | "accepted" | "declined" | "expired" | "revoked"
  message      String?
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  smartSpace SmartSpace @relation(fields: [smartSpaceId], references: [id], onDelete: Cascade)
  inviter    Entity     @relation("inviter", fields: [inviterId], references: [id])
  invitee    Entity?    @relation("invitee", fields: [inviteeId], references: [id])

  @@unique([smartSpaceId, inviteeEmail])
  @@index([inviteeEmail, status])
  @@index([inviteeId, status])
  @@map("invitations")
}

// =============================================================================
// MESSAGE RESPONSE — Responses to interactive messages (votes, confirmations, etc.)
// =============================================================================

model MessageResponse {
  id           String   @id @default(uuid()) @db.Uuid
  messageId    String   @map("message_id") @db.Uuid
  smartSpaceId String   @map("smart_space_id") @db.Uuid
  entityId     String   @map("entity_id") @db.Uuid
  entityName   String   @map("entity_name")
  entityType   String   @map("entity_type") // "human" | "agent"
  value        Json     @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  message    SmartSpaceMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  smartSpace SmartSpace        @relation(fields: [smartSpaceId], references: [id], onDelete: Cascade)
  entity     Entity            @relation(fields: [entityId], references: [id])

  @@unique([messageId, entityId])
  @@index([messageId])
  @@map("message_responses")
}

// =============================================================================
// MEDIA ASSET — Uploaded files, images, audio, video
// =============================================================================

model MediaAsset {
  id           String   @id @default(uuid()) @db.Uuid
  entityId     String   @map("entity_id") @db.Uuid
  mimeType     String   @map("mime_type")
  size         Int      // bytes
  url          String
  thumbnailUrl String?  @map("thumbnail_url")
  metadata     Json?    @db.JsonB // width, height, duration, transcription, etc.
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  entity Entity @relation(fields: [entityId], references: [id])

  @@index([entityId])
  @@map("media_assets")
}

// =============================================================================
// BASE — Groups humans + Haseefs together
// =============================================================================

model Base {
  id               String   @id @default(uuid()) @db.Uuid
  name             String
  avatarUrl        String?  @map("avatar_url")
  inviteCode       String   @unique @map("invite_code") // e.g. "FAMILY-7Q4K"
  inviteLinkActive Boolean  @default(true) @map("invite_link_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  members        BaseMember[]
  defaultUsers   User[]          @relation("userDefaultBase")
  scopeInstances ScopeInstance[]

  @@map("bases")
}

// =============================================================================
// BASE MEMBER — Entity (human or Haseef) belonging to a Base
// =============================================================================

model BaseMember {
  id        String   @id @default(uuid()) @db.Uuid
  baseId    String   @map("base_id") @db.Uuid
  entityId  String   @map("entity_id") @db.Uuid
  role      String   @default("member") // "owner" | "admin" | "member"
  joinedAt  DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)

  base   Base   @relation(fields: [baseId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([baseId, entityId])
  @@index([entityId])
  @@map("base_members")
}

// =============================================================================
// HASEEF OWNERSHIP — Links Users to Haseefs (in Core) and Entities (in Spaces)
// =============================================================================

// =============================================================================
// HASEEF SCHEDULE — Scheduled plans (recurring cron or one-time)
// =============================================================================

model HaseefSchedule {
  id              String    @id @default(uuid()) @db.Uuid
  haseefId        String    @map("haseef_id")       // Core haseef UUID (not FK — lives in Core DB)
  agentEntityId   String    @map("agent_entity_id") @db.Uuid
  description     String                             // What this schedule is for
  type            String                             // "recurring" | "one_time"
  cronExpression  String?   @map("cron_expression")  // e.g. "0 6 * * *" for recurring
  scheduledAt     DateTime? @map("scheduled_at") @db.Timestamptz(6) // For one_time
  timezone        String    @default("UTC")          // e.g. "Asia/Riyadh"
  nextRunAt       DateTime  @map("next_run_at") @db.Timestamptz(6)
  lastRunAt       DateTime? @map("last_run_at") @db.Timestamptz(6)
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([haseefId, active])
  @@index([nextRunAt, active])
  @@map("haseef_schedules")
}

model HaseefOwnership {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id")
  haseefId    String   @map("haseef_id") // Core haseef UUID
  entityId    String   @map("entity_id") @db.Uuid
  coreApiKey  String?  @map("core_api_key") @db.Text // Encrypted per-haseef Core API key (hsk_haseef_*)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id])

  @@unique([userId, haseefId])
  @@index([userId])
  @@map("haseef_ownerships")
}

// =============================================================================
// SCOPE TEMPLATE — Blueprint for a scope type (prebuilt or custom)
// =============================================================================

model ScopeTemplate {
  id                    String   @id @default(uuid()) @db.Uuid
  slug                  String   @unique                          // "spaces", "scheduler", "whatsapp", etc.
  name                  String                                    // Display name
  description           String   @default("")
  icon                  String?                                   // Icon name or URL
  category              String   @default("prebuilt")             // "prebuilt" | "custom"
  configSchema          Json     @default("{}") @map("config_schema") @db.JsonB  // JSON Schema for user config
  requiredProfileFields String[] @default([]) @map("required_profile_fields")    // e.g. ["phone"] for WhatsApp
  tools                 Json     @default("[]") @db.JsonB         // [{name, description, inputSchema}]
  instructions          String?  @db.Text                         // Scope-level instructions for haseef prompt
  sourceCode            String?  @map("source_code") @db.Text     // Bundled JS for custom scopes (null for prebuilt)
  imageUrl              String?  @map("image_url")                // Default Docker image (e.g. "hsafa/scope-postgres:latest")
  authorId              String?  @map("author_id")                // userId of developer (null for prebuilt)
  published             Boolean  @default(false)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  instances ScopeInstance[]

  @@map("scope_templates")
}

// =============================================================================
// SCOPE INSTANCE — A configured, named instance of a template
// =============================================================================

model ScopeInstance {
  id          String   @id @default(uuid()) @db.Uuid
  templateId  String   @map("template_id") @db.Uuid
  name        String                                    // User-chosen name ("personal-whatsapp")
  scopeName   String   @unique @map("scope_name")       // Scope name registered in Core (same as name by default)
  description String?
  ownerId     String?  @map("owner_id")                 // userId (null = platform-owned)
  baseId      String?  @map("base_id") @db.Uuid         // If shared with a Base (null = private)
  active          Boolean  @default(true)

  coreScopeKey String?  @map("core_scope_key") @db.Text  // Encrypted per-scope Core API key (hsk_scope_*)

  // ── Deployment ──────────────────────────────────────
  deploymentType  String   @default("platform") @map("deployment_type")   // "platform" | "custom" | "external" | "built-in"
  imageUrl        String?  @map("image_url")                              // Docker image URL (null for external/built-in)
  containerId     String?  @map("container_id")                            // Docker container ID (null for external/built-in)
  containerStatus String   @default("stopped") @map("container_status")   // "stopped" | "starting" | "running" | "error" | "building"
  statusMessage   String?  @map("status_message")                          // Error message or status details
  lastHealthAt    DateTime? @map("last_health_at") @db.Timestamptz(6)      // Last successful health check
  port            Int?                                                     // Assigned port (if needed)

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  template ScopeTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  base     Base?               @relation(fields: [baseId], references: [id], onDelete: SetNull)
  configs  ScopeInstanceConfig[]

  @@index([templateId])
  @@index([ownerId])
  @@map("scope_instances")
}

// =============================================================================
// SCOPE INSTANCE CONFIG — Encrypted config values for a scope instance
// =============================================================================

model ScopeInstanceConfig {
  id         String   @id @default(uuid()) @db.Uuid
  instanceId String   @map("instance_id") @db.Uuid
  key        String                                   // Config field name ("apiKey", "phoneNumber")
  value      String   @db.Text                        // Encrypted for secrets, plain for non-secrets
  isSecret   Boolean  @default(false) @map("is_secret")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  instance ScopeInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([instanceId, key])
  @@map("scope_instance_configs")
}

// =============================================================================
// HASEEF WATCH — Database trigger watches (postgres scope)
// =============================================================================

model HaseefWatch {
  id              String   @id @default(uuid()) @db.Uuid
  haseefId        String   @map("haseef_id")
  instanceId      String   @map("instance_id") @db.Uuid
  description     String
  tableName       String   @map("table_name")
  operation       String   // "INSERT" | "UPDATE" | "DELETE" | "ALL"
  whereCondition  String?  @map("where_condition")
  triggerName     String   @map("trigger_name")  // hsafa_watch_<id>
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([haseefId, active])
  @@index([instanceId])
  @@map("haseef_watches")
}

// =============================================================================
// API KEY — Encrypted LLM provider API keys (per user)
// =============================================================================

model ApiKey {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id")
  provider       String   // "openai" | "anthropic" | "openrouter"
  encryptedKey   String   @map("encrypted_key") @db.Text // AES-256-GCM encrypted
  keyHint        String   @map("key_hint") // last 4 chars for display (e.g. "...a1b2")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("api_keys")
}
