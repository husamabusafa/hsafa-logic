# =============================================================================
# Hsafa Use-Case App — Environment Variables (V5)
# =============================================================================

# Database: All use-case-app tables (users, entities, spaces, messages, etc.)
DATABASE_URL=postgresql://hsafa:hsafa123@localhost:5434/use_case_db

# Redis (must include password if set in docker-compose)
REDIS_URL=redis://:redis123@localhost:6379

# Spaces API auth keys (used by mobile apps / external clients)
SPACES_SECRET_KEY=sk_spaces_dev_secret_change_in_prod
SPACES_PUBLIC_KEY=pk_spaces_dev_public_change_in_prod

# JWT (MUST match core's JWT_SECRET for cross-service JWT verification)
JWT_SECRET=dev-jwt-secret-change-in-prod

# ----------- V5 Spaces Service Config -----------
# Core gateway URL
HSAFA_GATEWAY_URL=http://localhost:3001

# V5 API key for authenticating with Core (x-api-key header)
# The service auto-discovers all haseefs from Core and reads entityId from profileJson.
CORE_API_KEY=your_core_api_key_here

# Client-side env vars (prefixed with NEXT_PUBLIC_)
# After merge, spaces API is same-origin so GATEWAY_URL can be empty
# NEXT_PUBLIC_HSAFA_GATEWAY_URL=
# NEXT_PUBLIC_HSAFA_PUBLIC_KEY=pk_spaces_dev_public_change_in_prod
