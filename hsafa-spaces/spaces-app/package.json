{
  "name": "@hsafa/spaces-app",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Hsafa Spaces App — Independent chat/collaboration service with own DB, API, and auth",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ioredis": "^5.9.2",
    "jose": "^6.1.3",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "dotenv": "^17.3.1",
    "prisma": "^7.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5"
  }
}
