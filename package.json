{
  "name": "hsafa-logic",
  "version": "0.1.0",
  "private": true,
  "description": "Hsafa AI Agent Platform - Distributed agent runtime with React SDK",
  "scripts": {
    "dev:core": "pnpm --filter @hsafa/core dev",
    "dev:app": "pnpm --filter use-case-app dev",
    "dev": "pnpm run dev:core & pnpm run dev:app",
    "build:core": "pnpm --filter @hsafa/core build",
    "build:sdk": "pnpm --filter @hsafa/node build",
    "build": "pnpm -r build",
    "clean": "pnpm -r exec rm -rf node_modules dist .next"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
