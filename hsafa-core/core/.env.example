# =============================================================================
# Hsafa Core — Environment Variables
# =============================================================================

# Database (hsafa_db — shared with spaces via use-case-app)
DATABASE_URL=postgresql://hsafa:hsafa123@localhost:5434/hsafa_db

# Redis
REDIS_URL=redis://:redis123@localhost:6379

# Auth — single secret key for all API access
# Generate one via: npx tsx scripts/bootstrap-service-key.ts
SECRET_KEY=dev_secret_change_in_prod

# Server
PORT=3001
NODE_ENV=development

# LLM Providers (at least one required)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=
# OPENROUTER_API_KEY=
