# =============================================================================
# Hsafa Core — Environment Variables
# =============================================================================

# Database (hsafa_db — shared with spaces via use-case-app)
DATABASE_URL=postgresql://hsafa:hsafa123@localhost:5434/hsafa_db

# Redis
REDIS_URL=redis://:redis123@localhost:6379

# Auth keys
# NOTE: HSAFA_API_KEY is removed. Core now uses per-resource API keys (hsk_*).
# Generate a service key via: POST /api/keys { type: "service" }
# Then use that key as CORE_SERVICE_KEY in Spaces .env
HSAFA_SECRET_KEY=sk_dev_secret_key_change_in_prod
HSAFA_PUBLIC_KEY=pk_dev_public_key_change_in_prod
JWT_SECRET=dev-jwt-secret-change-in-prod
JWT_ENTITY_CLAIM=sub

# Server
PORT=3001
NODE_ENV=development

# LLM Providers (at least one required)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=
# OPENROUTER_API_KEY=
