generator client {
  provider      = "prisma-client-js"
  output        = "./generated/client"
  engineType    = "library"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum RunStatus {
  running
  completed
  failed
}

enum PlanStatus {
  pending
  running
  completed
  canceled
}

enum InboxEventStatus {
  pending
  processing
  processed
  failed
}

model Haseef {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  configJson  Json     @map("config_json") @db.JsonB
  configHash  String?  @map("config_hash")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  runs             Run[]
  memories         Memory[]
  plans            Plan[]
  goals            Goal[]
  consciousness    HaseefConsciousness?
  inboxEvents      InboxEvent[]
  pendingToolCalls PendingToolCall[]
  connections      HaseefExtension[]

  @@index([createdAt])
  @@map("haseefs")
}

model HaseefConsciousness {
  id              String   @id @default(uuid()) @db.Uuid
  haseefId        String   @unique @map("haseef_id") @db.Uuid
  messages        Json     @db.JsonB
  cycleCount      Int      @default(0) @map("cycle_count")
  tokenEstimate   Int      @default(0) @map("token_estimate")
  metadata        Json?    @db.JsonB
  lastCycleAt     DateTime @default(now()) @map("last_cycle_at") @db.Timestamptz(6)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)

  @@map("haseef_consciousness")
}

model Run {
  id              String    @id @default(uuid()) @db.Uuid
  haseefId        String    @map("haseef_id") @db.Uuid
  status          RunStatus @default(running)

  cycleNumber      Int @default(0) @map("cycle_number")
  inboxEventCount  Int @default(0) @map("inbox_event_count")
  stepCount        Int @default(0) @map("step_count")
  promptTokens     Int @default(0) @map("prompt_tokens")
  completionTokens Int @default(0) @map("completion_tokens")
  durationMs       Int @default(0) @map("duration_ms")

  triggerType      String? @map("trigger_type")
  triggerSource    String? @map("trigger_source")
  triggerEntityId  String? @map("trigger_entity_id") @db.Uuid
  triggerPayload   Json?   @map("trigger_payload") @db.JsonB

  startedAt   DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  errorMessage String?  @map("error_message")
  metadata     Json?    @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)

  inboxEvents      InboxEvent[]
  pendingToolCalls PendingToolCall[]

  @@index([haseefId, createdAt])
  @@index([haseefId, status])
  @@index([status, updatedAt])
  @@map("runs")
}

model Memory {
  id        String   @id @default(uuid()) @db.Uuid
  haseefId  String   @map("haseef_id") @db.Uuid
  key       String
  value     String   @db.Text
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)

  @@unique([haseefId, key])
  @@index([haseefId])
  @@map("memories")
}

model Plan {
  id           String     @id @default(uuid()) @db.Uuid
  haseefId     String     @map("haseef_id") @db.Uuid
  name         String
  instruction  String?    @db.Text
  isRecurring  Boolean    @default(false) @map("is_recurring")
  cron         String?
  scheduledAt  DateTime?  @map("scheduled_at") @db.Timestamptz(6)
  nextRunAt    DateTime?  @map("next_run_at") @db.Timestamptz(6)
  lastRunAt    DateTime?  @map("last_run_at") @db.Timestamptz(6)
  status       PlanStatus @default(pending)
  completedAt  DateTime?  @map("completed_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)

  @@index([haseefId, status])
  @@index([nextRunAt, status])
  @@map("plans")
}

model Goal {
  id          String   @id @default(uuid()) @db.Uuid
  haseefId    String   @map("haseef_id") @db.Uuid
  description String   @db.Text
  status      String   @default("active")
  priority    Int      @default(0)
  metadata    Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)

  @@index([haseefId, status])
  @@index([haseefId, priority])
  @@map("goals")
}

model InboxEvent {
  id              String           @id @default(uuid()) @db.Uuid
  haseefId        String           @map("haseef_id") @db.Uuid
  eventId         String           @map("event_id")
  type            String
  data            Json             @db.JsonB
  status          InboxEventStatus @default(pending)
  runId           String?          @map("run_id") @db.Uuid

  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  processedAt     DateTime?        @map("processed_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)
  run    Run?   @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@unique([haseefId, eventId])
  @@index([haseefId, status])
  @@index([runId])
  @@map("inbox_events")
}

model Extension {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @unique
  description    String?
  extensionKey   String   @unique @map("extension_key")
  instructions   String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tools       ExtensionTool[]
  connections HaseefExtension[]

  @@map("extensions")
}

model ExtensionTool {
  id          String   @id @default(uuid()) @db.Uuid
  extensionId String   @map("extension_id") @db.Uuid
  name        String
  description String   @db.Text
  inputSchema Json     @map("input_schema") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  extension Extension @relation(fields: [extensionId], references: [id], onDelete: Cascade)

  @@unique([extensionId, name])
  @@map("extension_tools")
}

model HaseefExtension {
  id          String   @id @default(uuid()) @db.Uuid
  haseefId    String   @map("haseef_id") @db.Uuid
  extensionId String   @map("extension_id") @db.Uuid
  config      Json?    @db.JsonB
  enabled     Boolean  @default(true)
  connectedAt DateTime @default(now()) @map("connected_at") @db.Timestamptz(6)

  haseef    Haseef    @relation(fields: [haseefId], references: [id], onDelete: Cascade)
  extension Extension @relation(fields: [extensionId], references: [id], onDelete: Cascade)

  @@unique([haseefId, extensionId])
  @@index([haseefId])
  @@index([extensionId])
  @@map("haseef_extensions")
}

model PendingToolCall {
  id              String    @id @default(uuid()) @db.Uuid
  haseefId        String    @map("haseef_id") @db.Uuid
  runId           String    @map("run_id") @db.Uuid
  toolCallId      String    @unique @map("tool_call_id")
  toolName        String    @map("tool_name")
  args            Json      @db.JsonB
  status          String    @default("pending")
  result          Json?     @db.JsonB
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt      DateTime? @map("resolved_at") @db.Timestamptz(6)
  expiresAt       DateTime? @map("expires_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)
  run    Run    @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([haseefId, status])
  @@index([status, expiresAt])
  @@map("pending_tool_calls")
}
