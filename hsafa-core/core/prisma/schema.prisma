generator client {
  provider        = "prisma-client-js"
  output          = "./generated/client"
  engineType      = "library"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  // extensions = [vector] // enable when pgvector is available
}

// =============================================================================
// Hsafa Core v7 — Data Model
//
// Brain: Haseef profile + 4 memory types + runs
// Body: Scopes (global tool registry) connected via SSE
// Stateless invocations: trigger → run → done
// =============================================================================

enum RunStatus {
  running
  completed
  interrupted
  failed
}

// =============================================================================
// Haseef — The agent identity
// =============================================================================

model Haseef {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  profileJson Json?    @map("profile_json") @db.JsonB // { phone, email, robotId, ... } — routing table
  configJson  Json     @map("config_json") @db.JsonB  // { model, instructions, ... }
  scopes      String[] @default(["spaces"])              // ["spaces", "scheduler", "whatsapp"]
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  runs       Run[]
  episodic   EpisodicMemory[]
  semantic   SemanticMemory[]
  social     SocialMemory[]
  procedural ProceduralMemory[]

  @@index([createdAt])
  @@map("haseefs")
}

// =============================================================================
// Scopes — Global tool registry (services register tools here)
// =============================================================================

model Scope {
  id         String    @id @default(uuid()) @db.Uuid
  name       String    @unique               // "whatsapp", "spaces", "body"
  connected  Boolean   @default(false)       // is the service currently connected?
  lastSeenAt DateTime? @map("last_seen_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tools ScopeTool[]

  @@map("scopes")
}

model ScopeTool {
  id          String   @id @default(uuid()) @db.Uuid
  scopeId     String   @map("scope_id") @db.Uuid
  name        String
  description String
  inputSchema Json     @map("input_schema") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  scope Scope @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@unique([scopeId, name])
  @@index([scopeId])
  @@map("scope_tools")
}

// =============================================================================
// Runs — Stateless invocations: trigger → think → act → done
// =============================================================================

model Run {
  id               String    @id @default(uuid()) @db.Uuid
  haseefId         String    @map("haseef_id") @db.Uuid
  status           RunStatus @default(running)

  triggerScope     String?   @map("trigger_scope")    // "whatsapp", "spaces"
  triggerType      String?   @map("trigger_type")     // "message", "email_received"
  summary          String?   @db.Text                 // run summary from done tool

  stepCount        Int       @default(0) @map("step_count")
  promptTokens     Int       @default(0) @map("prompt_tokens")
  completionTokens Int       @default(0) @map("completion_tokens")
  durationMs       Int       @default(0) @map("duration_ms")

  startedAt        DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt      DateTime? @map("completed_at") @db.Timestamptz(6)
  errorMessage     String?   @map("error_message")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)

  @@index([haseefId, createdAt])
  @@index([haseefId, status])
  @@index([status, updatedAt])
  @@map("runs")
}

// =============================================================================
// Memory — 4 structured types
// =============================================================================

// Episodic: what happened in past runs (run summaries, searchable)
model EpisodicMemory {
  id        String   @id @default(uuid()) @db.Uuid
  haseefId  String   @map("haseef_id") @db.Uuid
  runId     String?  @map("run_id") @db.Uuid
  summary   String   @db.Text
  context   Json?    @db.JsonB                       // { triggerScope, triggerType, toolsUsed, ... }
  // embedding Float[] // pgvector — enable when available
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)

  @@index([haseefId])
  @@index([haseefId, createdAt])
  @@map("episodic_memories")
}

// Semantic: facts the haseef knows (key-value, searchable)
model SemanticMemory {
  id             String    @id @default(uuid()) @db.Uuid
  haseefId       String    @map("haseef_id") @db.Uuid
  key            String
  value          String    @db.Text
  importance     Int       @default(5)                // 1-10
  // embedding   Float[]   // pgvector — enable when available
  lastRecalledAt DateTime? @map("last_recalled_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)

  @@unique([haseefId, key])
  @@index([haseefId])
  @@index([haseefId, importance])
  @@map("semantic_memories")
}

// Social: person models — what the haseef knows about people
model SocialMemory {
  id              String    @id @default(uuid()) @db.Uuid
  haseefId        String    @map("haseef_id") @db.Uuid
  entityName      String    @map("entity_name")       // "Husam", "Sara"
  observations    Json?     @db.JsonB                  // { preferences, style, traits }
  relationship    String?   @db.Text                   // "close friend", "manager", etc.
  lastInteraction DateTime? @map("last_interaction") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)

  @@unique([haseefId, entityName])
  @@map("social_memories")
}

// Procedural: learned patterns — what works in specific situations
model ProceduralMemory {
  id         String   @id @default(uuid()) @db.Uuid
  haseefId   String   @map("haseef_id") @db.Uuid
  trigger    String   @db.Text                        // "when someone asks about pricing"
  response   String   @db.Text                        // "use get_pricing tool with their plan"
  confidence Float    @default(0.5)                   // 0-1, increases with successful use
  hitCount   Int      @default(0) @map("hit_count")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)

  @@index([haseefId])
  @@map("procedural_memories")
}
