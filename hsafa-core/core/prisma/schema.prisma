generator client {
  provider        = "prisma-client-js"
  output          = "./generated/client"
  engineType      = "library"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  // extensions = [vector] // temporarily disabled for db push without pgvector
}

// =============================================================================
// Hsafa Core v5 — Data Model
//
// Seven tables. No context table — services communicate through tools and events.
// =============================================================================

enum RunStatus {
  running
  completed
  failed
}

model Haseef {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  profileJson Json?    @map("profile_json") @db.JsonB // identity: phone, email, location, bio (admin-managed)
  configJson  Json     @map("config_json") @db.JsonB  // model, instructions, consciousness settings
  configHash  String?  @map("config_hash")
  scopes      String[] @default([]) // v7: active scope names ["spaces", "whatsapp", "body"]
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  consciousness HaseefConsciousness?
  memories      Memory[]
  haseefScopes  HaseefScope[]
  tools         HaseefTool[]
  archive       ConsciousnessArchive[]
  snapshots     ConsciousnessSnapshot[]
  inboxEvents   InboxEvent[]
  runs          Run[]

  @@index([createdAt])
  @@map("haseefs")
}

// =============================================================================
// V7 Global Scope Tables
// Tools registered globally by services (not per-haseef).
// Haseefs activate scopes by adding scope name to their scopes[] array.
// =============================================================================

model Scope {
  id         String    @id @default(uuid()) @db.Uuid
  name       String    @unique               // "whatsapp", "spaces", "body"
  connected  Boolean   @default(false)       // is the service currently connected?
  lastSeenAt DateTime? @map("last_seen_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tools ScopeTool[]

  @@map("scopes")
}

model ScopeTool {
  id          String   @id @default(uuid()) @db.Uuid
  scopeId     String   @map("scope_id") @db.Uuid
  name        String
  description String
  inputSchema Json     @map("input_schema") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  scope Scope @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@unique([scopeId, name])
  @@index([scopeId])
  @@map("scope_tools")
}

model HaseefConsciousness {
  id            String   @id @default(uuid()) @db.Uuid
  haseefId      String   @unique @map("haseef_id") @db.Uuid
  messages      Json     @db.JsonB // ModelMessage[] — conversation only, NO system prompt
  cycleCount    Int      @default(0) @map("cycle_count")
  tokenEstimate Int      @default(0) @map("token_estimate")
  lastCycleAt   DateTime @default(now()) @map("last_cycle_at") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)

  @@map("haseef_consciousness")
}

model Run {
  id              String    @id @default(uuid()) @db.Uuid
  haseefId        String    @map("haseef_id") @db.Uuid
  status          RunStatus @default(running)

  cycleNumber      Int @default(0) @map("cycle_number")
  inboxEventCount  Int @default(0) @map("inbox_event_count")
  stepCount        Int @default(0) @map("step_count")
  promptTokens     Int @default(0) @map("prompt_tokens")
  completionTokens Int @default(0) @map("completion_tokens")
  durationMs       Int @default(0) @map("duration_ms")

  triggerScope     String? @map("trigger_scope")
  triggerType      String? @map("trigger_type")

  startedAt    DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt  DateTime? @map("completed_at") @db.Timestamptz(6)
  errorMessage String?   @map("error_message")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)

  @@index([haseefId, createdAt])
  @@index([haseefId, status])
  @@index([status, updatedAt])
  @@map("runs")
}

model Memory {
  id             String    @id @default(uuid()) @db.Uuid
  haseefId       String    @map("haseef_id") @db.Uuid
  key            String
  value          String    @db.Text
  importance     Int       @default(5) // 1-10, set by the Haseef
  // embedding      Unsupported("vector(1536)")? // pgvector for semantic search — disabled without pgvector
  lastRecalledAt DateTime? @map("last_recalled_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)

  @@unique([haseefId, key])
  @@index([haseefId])
  @@index([haseefId, importance])
  @@map("memories")
}

model HaseefScope {
  id           String   @id @default(uuid()) @db.Uuid
  haseefId     String   @map("haseef_id") @db.Uuid
  scope        String   // "spaces", "whatsapp", etc.
  instructions String?  @db.Text // scope-level instructions injected into the Haseef's prompt
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)
  tools  HaseefTool[]

  @@unique([haseefId, scope])
  @@index([haseefId])
  @@map("haseef_scopes")
}

model HaseefTool {
  id          String   @id @default(uuid()) @db.Uuid
  haseefId    String   @map("haseef_id") @db.Uuid
  scope       String   // references HaseefScope(haseefId, scope)
  name        String   // original tool name from the extension (e.g. "send_message")
  description String
  inputSchema Json     @map("input_schema") @db.JsonB // JSON Schema for args
  mode        String   @default("sync") // sync | fire_and_forget | async
  timeout     Int?     // ms, for sync mode
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  haseef      Haseef      @relation(fields: [haseefId], references: [id], onDelete: Cascade)
  haseefScope HaseefScope @relation(fields: [haseefId, scope], references: [haseefId, scope], onDelete: Cascade)

  @@unique([haseefId, scope, name])
  @@index([haseefId])
  @@index([haseefId, scope])
  @@map("haseef_tools")
}

model InboxEvent {
  id          String    @id @default(uuid()) @db.Uuid
  haseefId    String    @map("haseef_id") @db.Uuid
  eventId     String    @map("event_id")
  scope       String    // which service sent this: "spaces", "whatsapp", "core"
  type        String    // "message", "sensor_update", etc.
  data        Json      @db.JsonB
  attachments Json?     @db.JsonB // Attachment[] — images, audio, files
  status      String    @default("pending")
  processedAt DateTime? @map("processed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)

  @@unique([haseefId, eventId])
  @@index([haseefId])
  @@index([haseefId, status])
  @@map("inbox_events")
}

model ConsciousnessArchive {
  id           String                          @id @default(uuid()) @db.Uuid
  haseefId     String                          @map("haseef_id") @db.Uuid
  cycleNumber  Int                             @map("cycle_number")
  summary      String                          @db.Text // compact summary of what happened
  fullMessages Json                            @map("full_messages") @db.JsonB // original messages
  // embedding    Unsupported("vector(1536)")?    // pgvector for semantic search — disabled without pgvector
  createdAt    DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)

  @@index([haseefId])
  @@index([haseefId, cycleNumber])
  @@map("consciousness_archive")
}

model ConsciousnessSnapshot {
  id            String   @id @default(uuid()) @db.Uuid
  haseefId      String   @map("haseef_id") @db.Uuid
  cycleCount    Int      @map("cycle_count")
  messages      Json     @db.JsonB
  tokenEstimate Int      @default(0) @map("token_estimate")
  reason        String?  // "auto", "manual", "pre-compaction"
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  haseef Haseef @relation(fields: [haseefId], references: [id], onDelete: Cascade)

  @@index([haseefId, createdAt])
  @@map("consciousness_snapshots")
}
